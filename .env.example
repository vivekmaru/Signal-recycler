# Local server
PORT=3001
SIGNAL_RECYCLER_DB=./signal-recycler.sqlite
SIGNAL_RECYCLER_LOG_LEVEL=error
SIGNAL_RECYCLER_CONNECT_TIMEOUT_MS=60000

# Required for the real hackathon demo.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
SIGNAL_RECYCLER_CLASSIFIER_MODEL=gpt-5.1-mini

# Optional fallback only.
# Set to 1 for deterministic local UI demos that do not call Codex/OpenAI.
SIGNAL_RECYCLER_MOCK_CODEX=0
