# ─── Required ────────────────────────────────────────────────────────────────
# Must be a Project API key (sk-proj-...) — the Responses API requires it.
# The proxy uses this to authenticate requests it forwards to OpenAI.
OPENAI_API_KEY=

# ─── Optional — server config ─────────────────────────────────────────────────
PORT=3001
SIGNAL_RECYCLER_DB=./signal-recycler.sqlite

# Which directory Codex operates in. Defaults to this repo root.
# Point at any project: SIGNAL_RECYCLER_WORKDIR=/path/to/your/project
SIGNAL_RECYCLER_WORKDIR=

# Namespace for rules/sessions in the DB. Defaults to basename of WORKDIR.
SIGNAL_RECYCLER_PROJECT_ID=

# Model used for classifying turns and extracting rule candidates.
SIGNAL_RECYCLER_CLASSIFIER_MODEL=gpt-5.4-mini

# Where the proxy forwards traffic. Default is fine — only change if you are
# routing to a different OpenAI-compatible endpoint.
# WARNING: never set this to the proxy URL itself (http://127.0.0.1:3001/proxy)
SIGNAL_RECYCLER_UPSTREAM_URL=https://api.openai.com

# Set to error for useful failure logs. Leave unset to suppress request noise.
SIGNAL_RECYCLER_LOG_LEVEL=

# ─── Optional — mock mode ─────────────────────────────────────────────────────
# Set to 1 to run the UI demo without spending API calls.
SIGNAL_RECYCLER_MOCK_CODEX=0

# ─── Shell only — DO NOT put in this file ─────────────────────────────────────
# To route your terminal's `codex` CLI through Signal Recycler, add this to
# ~/.zshrc or ~/.bashrc — NOT here. Setting it here would cause the proxy to
# forward traffic back to itself.
#
#   export OPENAI_BASE_URL=http://127.0.0.1:3001/proxy
